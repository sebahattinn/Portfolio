---
import { languages, defaultLanguage } from '../../i18n';
---

<div class="lang-dropdown" id="lang-dropdown">
  <button class="lang-dropdown__trigger" type="button" id="lang-trigger" aria-haspopup="listbox" aria-expanded="false">
    <span class="lang-dropdown__current" id="lang-current">EN</span>
    <svg class="lang-dropdown__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
      <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class="lang-dropdown__menu" id="lang-menu" role="listbox">
    <button class="lang-dropdown__option" data-lang="en" type="button" role="option">
      <span class="lang-dropdown__code">EN</span>
      <span class="lang-dropdown__label">English</span>
    </button>
    <button class="lang-dropdown__option" data-lang="tr" type="button" role="option">
      <span class="lang-dropdown__code">TR</span>
      <span class="lang-dropdown__label">Türkçe</span>
    </button>
  </div>
</div>

