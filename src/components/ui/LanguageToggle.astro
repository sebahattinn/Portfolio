---
import { languages, defaultLanguage } from '../../i18n';
---

<div class="lang-toggle" id="lang-toggle">
  {Object.entries(languages).map(([code, label]) => (
    <button
      class:list={['lang-toggle__btn', { 'lang-toggle__btn--active': defaultLanguage === code }]}
      data-lang={code}
      type="button"
    >
      {label}
    </button>
  ))}
</div>

<script>
  type Language = 'en' | 'tr';
  
  const translations: Record<Language, Record<string, any>> = {
    en: {
      nav: {
        home: 'Home',
        about: 'About',
        techStack: 'Tech Stack',
        experience: 'Experience',
        projects: 'Projects'
      },
      footer: {
        builtWith: 'Built with Astro',
        rights: 'All rights reserved'
      },
      index: {
        heroTitle: 'Full-Stack Software Engineer',
        heroSubtitle: 'Building elegant solutions with .NET and Flutter',
        viewProjects: 'View Projects',
        learnMore: 'Learn More',
        featuredProjects: 'Featured Projects'
      },
      about: {
        title: 'About',
        background: 'Background',
        backgroundText: 'A dedicated software engineer with a passion for building robust, scalable applications. Specializing in enterprise solutions with .NET and cross-platform mobile development with Flutter. Focused on Clean Code principles, test-driven development, and delivering high-quality software that makes a real impact.',
        expertise: 'Expertise',
        expertiseList: ['Full-Stack Development', 'API Design and Integration', 'Database Architecture', 'Cross-Platform Mobile Development', 'Cloud Infrastructure'],
        values: 'Values',
        qualityFirst: 'Quality First',
        qualityFirstDesc: 'Writing clean, maintainable code that stands the test of time.',
        continuousLearning: 'Continuous Learning',
        continuousLearningDesc: 'Staying current with emerging technologies and best practices.',
        userFocus: 'User Focus',
        userFocusDesc: 'Building solutions that solve real problems for real users.',
        getInTouch: 'Get in Touch'
      },
      projects: {
        title: 'Projects',
        viewDetails: 'View Details',
        technologies: 'Technologies',
        highlights: 'Highlights'
      },
      tech: {
        title: 'Tech Stack',
        backend: 'Backend',
        frontend: 'Frontend',
        mobile: 'Mobile',
        database: 'Database',
        devops: 'DevOps',
        tools: 'Tools'
      },
      experience: {
        title: 'Experience'
      }
    },
    tr: {
      nav: {
        home: 'Ana Sayfa',
        about: 'Hakkında',
        techStack: 'Teknolojiler',
        experience: 'Deneyim',
        projects: 'Projeler'
      },
      footer: {
        builtWith: 'Astro ile yapıldı',
        rights: 'Tüm hakları saklıdır'
      },
      index: {
        heroTitle: 'Yazılım Mühendisi',
        heroSubtitle: '.NET ve Flutter ile zarif çözümler geliştirme',
        viewProjects: 'Projeleri Gör',
        learnMore: 'Daha Fazla',
        featuredProjects: 'Öne Çıkan Projeler'
      },
      about: {
        title: 'Hakkında',
        background: 'Geçmiş',
        backgroundText: 'Güçlü, ölçeklenebilir uygulamalar geliştirme tutkusu olan özverili bir yazılım mühendisi. .NET ile kurumsal çözümler ve Flutter ile çapraz platform mobil geliştirme uzmanlığı. Clean Code prensipleri, test odaklı geliştirme ve gerçekten etki yaratan kaliteli yazılımlar sunmaya odaklanıyor.',
        expertise: 'Uzmanlık',
        expertiseList: ['Tam Yığın Geliştirme', 'API Tasarımı ve Entegrasyonu', 'Veritabanı Mimarisi', 'Çapraz Platform Mobil Geliştirme', 'Bulut Altyapısı'],
        values: 'Değerler',
        qualityFirst: 'Kalite Önce',
        qualityFirstDesc: 'Zamanın testini geçen temiz, bakımı kolay kod yazmak.',
        continuousLearning: 'Sürekli Öğrenme',
        continuousLearningDesc: 'Yeni teknolojiler ve en iyi uygulamalar ile güncel kalmak.',
        userFocus: 'Kullanıcı Odaklılık',
        userFocusDesc: 'Gerçek kullanıcıların gerçek sorunlarını çözen çözümler geliştirmek.',
        getInTouch: 'İletişime Geç'
      },
      projects: {
        title: 'Projeler',
        viewDetails: 'Detayları Gör',
        technologies: 'Teknolojiler',
        highlights: 'Özellikler'
      },
      tech: {
        title: 'Teknolojiler',
        backend: 'Backend',
        frontend: 'Frontend',
        mobile: 'Mobil',
        database: 'Veritabanı',
        devops: 'DevOps',
        tools: 'Araçlar'
      },
      experience: {
        title: 'Deneyim'
      }
    }
  };

  const STORAGE_KEY = 'sebotech-lang';

  function getCurrentLanguage(): Language {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === 'en' || stored === 'tr') {
      return stored;
    }
    return 'en';
  }

  function setLanguage(lang: Language) {
    localStorage.setItem(STORAGE_KEY, lang);
    updateUI(lang);
  }

  function getNestedValue(obj: any, path: string): string | undefined {
    const keys = path.split('.');
    let current = obj;
    for (const key of keys) {
      if (current && typeof current === 'object' && key in current) {
        current = current[key];
      } else {
        return undefined;
      }
    }
    return typeof current === 'string' ? current : undefined;
  }

  function updateUI(lang: Language) {
    const t = translations[lang];
    
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const value = getNestedValue(t, key);
        if (value) {
          el.textContent = value;
        }
      }
    });

    document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (key) {
        const value = getNestedValue(t, key);
        if (value && el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
          (el as HTMLInputElement).placeholder = value;
        }
      }
    });

    document.querySelectorAll('.lang-toggle__btn').forEach((btn) => {
      const btnLang = btn.getAttribute('data-lang');
      btn.classList.toggle('lang-toggle__btn--active', btnLang === lang);
    });
  }

  function init() {
    const lang = getCurrentLanguage();
    updateUI(lang);

    document.querySelectorAll('.lang-toggle__btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const newLang = (btn.getAttribute('data-lang') as Language);
        setLanguage(newLang);
      });
    });
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  .lang-toggle {
    display: flex;
    gap: var(--spacing-1);
    background: var(--color-bg-secondary);
    padding: 2px;
    border-radius: 4px;
  }

  .lang-toggle__btn {
    padding: 4px 8px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-secondary);
    background: transparent;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .lang-toggle__btn:hover {
    color: var(--color-text-primary);
  }

  .lang-toggle__btn--active {
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
  }
</style>
