  const STORAGE_KEY = 'sebotech-lang';

  function getCurrentLanguage(): Language {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === 'en' || stored === 'tr') return stored;
    return 'en';
  }

  function setLanguage(lang: Language) {
    localStorage.setItem(STORAGE_KEY, lang);
    updateUI(lang);
    closeDropdown();
  }

  function getNestedValue(obj: any, path: string): string | undefined {
    const keys = path.split('.');
    let current = obj;
    for (const key of keys) {
      if (current && typeof current === 'object' && key in current) {
        current = current[key];
      } else {
        return undefined;
      }
    }
    return typeof current === 'string' ? current : undefined;
  }

  function updateUI(lang: Language) {
    const t = translations[lang];

    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const value = getNestedValue(t, key);
        if (value !== undefined) {
          el.textContent = value;
        }
      }
    });

    const currentEl = document.getElementById('lang-current');
    if (currentEl) currentEl.textContent = lang.toUpperCase();

    document.querySelectorAll('.lang-dropdown__option').forEach((btn) => {
      const btnLang = btn.getAttribute('data-lang');
      btn.classList.toggle('lang-dropdown__option--active', btnLang === lang);
    });
  }

  function openDropdown() {
    const menu = document.getElementById('lang-menu');
    const trigger = document.getElementById('lang-trigger');
    const dropdown = document.getElementById('lang-dropdown');
    menu?.classList.add('lang-dropdown__menu--open');
    trigger?.setAttribute('aria-expanded', 'true');
    dropdown?.classList.add('lang-dropdown--open');
  }

  function closeDropdown() {
    const menu = document.getElementById('lang-menu');
    const trigger = document.getElementById('lang-trigger');
    const dropdown = document.getElementById('lang-dropdown');
    menu?.classList.remove('lang-dropdown__menu--open');
    trigger?.setAttribute('aria-expanded', 'false');
    dropdown?.classList.remove('lang-dropdown--open');
  }

  function init() {
    const lang = getCurrentLanguage();
    updateUI(lang);

    const trigger = document.getElementById('lang-trigger');
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = document.getElementById('lang-menu')?.classList.contains('lang-dropdown__menu--open');
      isOpen ? closeDropdown() : openDropdown();
    });

    document.querySelectorAll('.lang-dropdown__option').forEach((btn) => {
      btn.addEventListener('click', () => {
        const newLang = btn.getAttribute('data-lang') as Language;
        setLanguage(newLang);
      });
    });

    document.addEventListener('click', closeDropdown);
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  .lang-dropdown {
    position: relative;
  }

  .lang-dropdown__trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 10px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: inherit;
  }

  .lang-dropdown__trigger:hover,
  .lang-dropdown--open .lang-dropdown__trigger {
    border-color: var(--color-border-hover);
    background: var(--color-bg-tertiary);
  }

  .lang-dropdown__current {
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
  }

  .lang-dropdown__chevron {
    color: var(--color-text-tertiary);
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .lang-dropdown--open .lang-dropdown__chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown__menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 130px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
    z-index: 200;
  }

  .lang-dropdown__menu--open {
    opacity: 1;
    pointer-events: all;
    transform: translateY(0);
  }

  .lang-dropdown__option {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    width: 100%;
    padding: 8px 14px;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast);
    font-family: inherit;
    text-align: left;
  }

  .lang-dropdown__option:hover {
    background: var(--color-bg-tertiary);
  }

  .lang-dropdown__option--active {
    background: var(--color-bg-tertiary);
  }

  .lang-dropdown__code {
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
    min-width: 20px;
  }

  .lang-dropdown__option--active .lang-dropdown__code {
    color: var(--color-accent);
  }

  .lang-dropdown__label {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }
</style>
