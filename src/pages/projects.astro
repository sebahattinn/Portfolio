---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import '../styles/global.css';

const title = 'Projects - SeboTech';
const description = 'Featured projects showcasing software development expertise.';

const projects = [
  {
    title: 'E-paraf',
    description: 'Digital signature platform enabling secure document workflows and legally binding electronic signatures for businesses.',
    technologies: ['C#', '.NET Core', 'PostgreSQL', 'Azure'],
    highlights: ['Bank-grade security', 'Multi-language support', 'API integration'],
    link: '#'
  },
  {
    title: 'Digital Will',
    description: 'Secure digital estate planning platform for managing and transferring digital assets after life events.',
    technologies: ['Flutter', 'Firebase', 'Node.js'],
    highlights: ['End-to-end encryption', 'Mobile-first design', 'Legal compliance'],
    link: '#'
  },
  {
    title: 'ImageBroadcast',
    description: 'Multi-platform image distribution system for media companies to manage and broadcast visual content.',
    technologies: ['Flutter', 'REST API', 'Cloud Storage'],
    highlights: ['Real-time sync', 'Batch processing', 'Analytics dashboard'],
    link: '#'
  }
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Header siteTitle="SeboTech" />
    
    <main class="main">
      <section class="projects">
        <div class="container">
          <h1 class="page-title">Projects</h1>
          
          <div class="projects__grid">
            {projects.map(project => (
              <Card variant="bordered" padding="lg" class="project-card">
                <h2 class="project-title">{project.title}</h2>
                <p class="project-description">{project.description}</p>
                
                <div class="project-section">
                  <h3 class="section-label">Technologies</h3>
                  <div class="tech-tags">
                    {project.technologies.map(tech => (
                      <span class="tech-tag">{tech}</span>
                    ))}
                  </div>
                </div>
                
                <div class="project-section">
                  <h3 class="section-label">Highlights</h3>
                  <ul class="highlights-list">
                    {project.highlights.map(h => (
                      <li>{h}</li>
                    ))}
                  </ul>
                </div>

                <div class="project-actions">
                  <Button href={project.link} variant="secondary" size="sm">
                    View Details
                  </Button>
                </div>
              </Card>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .projects {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
    text-align: center;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--spacing-6);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: fit-content;
  }

  .project-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-3);
  }

  .project-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-5);
  }

  .project-section {
    margin-bottom: var(--spacing-4);
  }

  .section-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-2);
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .tech-tag {
    padding: var(--spacing-1) var(--spacing-2);
    background-color: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .highlights-list li {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-4);
    position: relative;
  }

  .highlights-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    background-color: var(--color-accent);
    border-radius: 50%;
  }

  .project-actions {
    margin-top: auto;
    padding-top: var(--spacing-4);
  }
</style>
