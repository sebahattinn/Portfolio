---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Modal from '../components/ui/Modal.astro';
import '../styles/global.css';

const title = 'Projects - Sebahattin';
const description = 'Featured projects showcasing software development expertise.';

const projects = [
  {
    id: 'eparaf',
    title: 'E-paraf',
    shortDescription: 'Enterprise digital signature platform with Clean Architecture. Legally binding e-signatures, role-based access, and payment system integration.',
    description: 'A comprehensive enterprise digital signature platform enabling secure document workflows and legally binding electronic signatures for businesses. Built with Clean Architecture and DDD patterns. Features role-based access control, payment system integration, and real-time notifications. The platform handles high-volume document processing with enterprise-grade security.',
    technologies: ['ASP.NET Core', 'C#', 'PostgreSQL', 'Redis', 'Docker', 'RabbitMQ', 'Clean Architecture', 'DDD', 'Entity Framework Core', 'REST API'],
    highlights: ['Clean Architecture & Domain-Driven Design', 'Role-based access control (RBAC)', 'Payment system integration', 'Redis caching for high performance', 'RabbitMQ message queue for async processing', 'Real-time notifications via SignalR', 'Containerized with Docker', 'Comprehensive audit logging'],
    link: '#'
  },
  {
    id: 'digitalwill',
    title: 'Digital Will',
    shortDescription: 'Secure digital estate planning app with end-to-end encrypted storage for digital assets and beneficiary management.',
    description: 'A secure digital estate planning platform for managing and transferring digital assets after life events. Features end-to-end encryption and legal compliance. Users can securely store passwords, cryptocurrency keys, social media accounts, and important documents with beneficiary management.',
    technologies: ['Flutter', 'Dart', 'Firebase', 'BLoC', 'Firebase Auth', 'Cloud Firestore', 'AES-256'],
    highlights: ['End-to-end encryption (AES-256 + RSA)', 'Mobile-first responsive design', 'Legal compliance (GDPR, KVKK)', 'Digital asset inventory management', 'Beneficiary management system', 'Secure document storage'],
    link: '#'
  },
  {
    id: 'imagebroadcast',
    title: 'ImageBroadcast',
    shortDescription: 'Multi-platform image distribution system for media management with real-time sync and CDN integration.',
    description: 'A multi-platform image distribution system for media companies to manage and broadcast visual content efficiently. Supports real-time synchronization across devices, batch processing for large media libraries, and CDN integration for fast global delivery.',
    technologies: ['Flutter', 'Dart', 'REST API', 'Firebase', 'Cloud Storage', 'Provider'],
    highlights: ['Real-time synchronization across devices', 'Batch processing for large media libraries', 'Analytics dashboard with insights', 'CDN integration for global delivery', 'Metadata management system', 'Automated image optimization'],
    link: '#'
  },
  {
    id: 'voicerecognition',
    title: 'Voice Recognition',
    shortDescription: 'Real-time speaker recognition and audio analysis machine learning application.',
    description: 'A machine learning application capable of real-time speaker recognition and audio analysis. Records audio through an easy-to-use interface, performs identity detection, and displays detailed analysis results. Implements deep learning and Random Forest algorithms for high-accuracy identification.',
    technologies: ['Python', 'Deep Learning', 'Random Forest', 'NumPy', 'Scikit-learn', 'Jupyter Notebook', 'Artificial Intelligence'],
    highlights: ['Real-time speaker recognition', 'Audio feature extraction', 'Deep learning model integration', 'Interactive Jupyter interface', 'Identity detection pipeline', 'High accuracy with ensemble methods'],
    link: 'https://github.com/sebahattinn/Voice-Recognition'
  },
  {
    id: 'earthquakealert',
    title: 'Flutter EarthquakeAlert',
    shortDescription: 'Flutter app that warns users before and during earthquakes to raise seismic awareness.',
    description: 'A Flutter application designed to raise earthquake awareness by providing real-time alerts and warnings before and during seismic events. Aims to help users prepare for and respond to earthquakes through timely notifications and educational content.',
    technologies: ['Flutter', 'Dart', 'Android Studio', 'Mobile Development', 'Push Notifications'],
    highlights: ['Real-time earthquake alerts', 'Pre-earthquake warning system', 'Awareness-focused UX', 'Cross-platform (Android/iOS)', 'Push notification integration', 'Educational content for preparedness'],
    link: '#'
  },
  {
    id: 'flowersepetim',
    title: 'FlowerSepetim',
    shortDescription: 'Test project implementing Clean Architecture principles with Vue.js frontend.',
    description: 'A personal test project built to practice and demonstrate Clean Architecture principles in a Vue-based frontend application. Serves as a sandbox for exploring architectural patterns, component design, and scalable project structures.',
    technologies: ['Vue.js', 'JavaScript', 'Clean Architecture', 'Component Design', 'Frontend Architecture'],
    highlights: ['Clean Architecture implementation', 'Component-based design', 'Scalable folder structure', 'Vue Composition API', 'Separation of concerns', 'Architectural pattern exploration'],
    link: 'https://github.com/sebahattinn/FlowerSepetim'
  }
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sebotech-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Header siteTitle="Sebahattin" />
    
    <main class="main">
      <section class="projects">
        <div class="container">
          <h1 class="page-title" data-i18n="projects.title">Projects</h1>
          
          <div class="projects__grid">
            {projects.map(project => (
              <button class="project-card" type="button" data-modal-open={`modal-${project.id}`}>
                <h2 class="project-title">{project.title}</h2>
                <p class="project-description">{project.shortDescription}</p>
                
                <div class="project-section">
                  <h3 class="section-label" data-i18n="projects.technologies">Technologies</h3>
                  <div class="tech-tags">
                    {project.technologies.map(tech => (
                      <span class="tech-tag">{tech}</span>
                    ))}
                  </div>
                </div>

                <div class="project-card__cta">
                  <span class="view-details" data-i18n="projects.viewDetails">View Details</span>
                </div>
              </button>
            ))}
          </div>
        </div>
      </section>
    </main>

    {projects.map(project => (
      <Modal id={`modal-${project.id}`} title={project.title}>
        <div class="modal-body">
          <p class="modal-description">{project.description}</p>
          
          <div class="modal-section">
            <h3 class="section-label" data-i18n="projects.technologies">Technologies</h3>
            <div class="tech-tags">
              {project.technologies.map(tech => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          </div>
          
          <div class="modal-section">
            <h3 class="section-label" data-i18n="projects.highlights">Highlights</h3>
            <ul class="highlights-list">
              {project.highlights.map(h => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        </div>
      </Modal>
    ))}

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .projects {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
    text-align: center;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--spacing-6);
    align-items: stretch;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--spacing-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-base);
    text-align: left;
    font-family: inherit;
  }

  .project-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .project-card:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .project-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-3);
  }

  .project-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-5);
  }

  .project-section {
    margin-bottom: var(--spacing-4);
  }

  .section-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-2);
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .tech-tag {
    padding: var(--spacing-1) var(--spacing-2);
    background-color: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }

  .project-card__cta {
    margin-top: auto;
    padding-top: var(--spacing-4);
  }

  .view-details {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  .project-card:hover .view-details {
    color: var(--color-accent-hover);
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .highlights-list li {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-4);
    position: relative;
  }

  .highlights-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    background-color: var(--color-accent);
    border-radius: 50%;
  }

  .modal-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }

  .modal-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .modal-section {
    margin-bottom: var(--spacing-2);
  }
</style>
