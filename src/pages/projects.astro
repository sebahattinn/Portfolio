---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Modal from '../components/ui/Modal.astro';
import '../styles/global.css';

const title = 'Projects - SeboTech';
const description = 'Featured projects showcasing software development expertise.';

const projects = [
  {
    id: 'eparaf',
    title: 'E-paraf',
    shortDescription: 'Digital signature platform for secure document workflows.',
    description: 'A comprehensive digital signature platform enabling secure document workflows and legally binding electronic signatures for businesses. Built with enterprise-grade security and compliance in mind.',
    technologies: ['C#', '.NET Core', 'PostgreSQL', 'Azure'],
    highlights: ['Bank-grade security', 'Multi-language support', 'API integration', 'Real-time notifications', 'Audit logging'],
    link: '#'
  },
  {
    id: 'digitalwill',
    title: 'Digital Will',
    shortDescription: 'Secure digital estate planning platform.',
    description: 'A secure digital estate planning platform for managing and transferring digital assets after life events. Features end-to-end encryption and legal compliance across multiple jurisdictions.',
    technologies: ['Flutter', 'Firebase', 'Node.js'],
    highlights: ['End-to-end encryption', 'Mobile-first design', 'Legal compliance', 'Asset inventory', 'Beneficiary management'],
    link: '#'
  },
  {
    id: 'imagebroadcast',
    title: 'ImageBroadcast',
    shortDescription: 'Multi-platform image distribution system.',
    description: 'A multi-platform image distribution system for media companies to manage and broadcast visual content efficiently. Supports real-time synchronization and batch processing.',
    technologies: ['Flutter', 'REST API', 'Cloud Storage'],
    highlights: ['Real-time sync', 'Batch processing', 'Analytics dashboard', 'CDN integration', 'Metadata management'],
    link: '#'
  }
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sebotech-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Header siteTitle="SeboTech" />
    
    <main class="main">
      <section class="projects">
        <div class="container">
          <h1 class="page-title">Projects</h1>
          
          <div class="projects__grid">
            {projects.map(project => (
              <button class="project-card" type="button" data-modal-open={`modal-${project.id}`}>
                <h2 class="project-title">{project.title}</h2>
                <p class="project-description">{project.shortDescription}</p>
                
                <div class="project-section">
                  <h3 class="section-label">Technologies</h3>
                  <div class="tech-tags">
                    {project.technologies.map(tech => (
                      <span class="tech-tag">{tech}</span>
                    ))}
                  </div>
                </div>

                <div class="project-card__cta">
                  <span class="view-details">View Details</span>
                </div>
              </button>
            ))}
          </div>
        </div>
      </section>
    </main>

    {projects.map(project => (
      <Modal id={`modal-${project.id}`} title={project.title}>
        <div class="modal-body">
          <p class="modal-description">{project.description}</p>
          
          <div class="modal-section">
            <h3 class="section-label">Technologies</h3>
            <div class="tech-tags">
              {project.technologies.map(tech => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          </div>
          
          <div class="modal-section">
            <h3 class="section-label">Highlights</h3>
            <ul class="highlights-list">
              {project.highlights.map(h => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        </div>
      </Modal>
    ))}

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .projects {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
    text-align: center;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--spacing-6);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: fit-content;
    padding: var(--spacing-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-base);
    text-align: left;
    font-family: inherit;
  }

  .project-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .project-card:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .project-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-3);
  }

  .project-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-5);
  }

  .project-section {
    margin-bottom: var(--spacing-4);
  }

  .section-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-2);
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .tech-tag {
    padding: var(--spacing-1) var(--spacing-2);
    background-color: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }

  .project-card__cta {
    margin-top: auto;
    padding-top: var(--spacing-4);
  }

  .view-details {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  .project-card:hover .view-details {
    color: var(--color-accent-hover);
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .highlights-list li {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-4);
    position: relative;
  }

  .highlights-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    background-color: var(--color-accent);
    border-radius: 50%;
  }

  .modal-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }

  .modal-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .modal-section {
    margin-bottom: var(--spacing-2);
  }
</style>
