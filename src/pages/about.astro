---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Card from '../components/ui/Card.astro';
import '../styles/global.css';

const title = 'About - Sebahattin';
const description = 'Learn about the background and experience of a Full-Stack Software Engineer.';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sebahattin-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Header siteTitle="Sebahattin" />
    
    <main class="main">
      <section class="about">
        <div class="container container--narrow">
          <h1 class="page-title" data-i18n="about.title">About</h1>

          <div class="about__content reveal-stagger">
            <Card variant="bordered" padding="lg">
              <h2 class="section-heading" data-i18n="about.background">Background</h2>
              <p class="text" data-i18n="about.backgroundPara1">
                Software Engineering graduate from Celal Bayar University (GPA: 3.20/4.00) with B1+ English proficiency.
                I specialize in building scalable, production-ready enterprise applications using .NET and Flutter.
              </p>
              <p class="text" data-i18n="about.backgroundPara2">
                I care deeply about clean code, SOLID principles, and long-term maintainability — not just making things work, but making them right.
                I've shipped features in production environments, worked within Clean Architecture and DDD patterns, and developed a habit of continuous improvement through code reviews, testing, and refactoring.
              </p>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="section-heading" data-i18n="about.expertise">Expertise</h2>
              <ul class="expertise-list">
                <li data-i18n="about.expertise1">Clean Architecture &amp; DDD</li>
                <li data-i18n="about.expertise2">Backend API Development</li>
                <li data-i18n="about.expertise3">Cross-Platform Mobile (Flutter)</li>
                <li data-i18n="about.expertise4">Database Design &amp; Optimization</li>
                <li data-i18n="about.expertise5">Code Review &amp; Refactoring</li>
                <li data-i18n="about.expertise6">Test-Driven Development</li>
                <li data-i18n="about.expertise7">Long-Term System Maintenance</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="section-heading" data-i18n="about.values">Values</h2>
              <ul class="values-list">
                <li>
                  <strong data-i18n="about.qualityFirst">Quality First</strong><span data-i18n="about.qualityFirstDesc"> — Writing clean, maintainable, and testable code isn't optional — it's the baseline. I consistently apply SOLID principles and design patterns to keep codebases healthy over time.</span>
                </li>
                <li>
                  <strong data-i18n="about.continuousImprovement">Continuous Improvement</strong><span data-i18n="about.continuousImprovementDesc"> — I actively participate in code reviews, write unit and integration tests, and regularly refactor to improve system quality. Learning is a daily habit, not an occasional event.</span>
                </li>
                <li>
                  <strong data-i18n="about.productionMindset">Production Mindset</strong><span data-i18n="about.productionMindsetDesc"> — I build with production in mind: observability, error handling, performance, and scalability. Features aren't done until they're deployed and running reliably.</span>
                </li>
              </ul>
            </Card>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .about {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
  }

  .about__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .section-heading {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-4);
  }

  .text {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-4);
  }

  .text:last-child {
    margin-bottom: 0;
  }

  .expertise-list,
  .values-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .expertise-list li {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-5);
    position: relative;
  }

  .expertise-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    background-color: var(--color-accent);
    border-radius: 50%;
  }

  .values-list li {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
  }

  .values-list strong {
    color: var(--color-text-primary);
  }

  .cta {
    margin-top: var(--spacing-8);
    display: flex;
    justify-content: center;
  }
</style>
