---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Card from '../components/ui/Card.astro';
import '../styles/global.css';

const title = 'Tech Stack - Sebahattin';
const description = 'Technologies and tools used for building software solutions.';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sebotech-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Header siteTitle="Sebahattin" />
    
    <main class="main">
      <section class="tech">
        <div class="container">
          <h1 class="page-title">Tech Stack</h1>
          
          <div class="tech__grid">
            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Backend & Server</h2>
              <ul class="tech-list">
                <li>C# / .NET 6+</li>
                <li>ASP.NET Core Web API</li>
                <li>Entity Framework Core</li>
                <li>gRPC & GraphQL</li>
                <li>Microservices Architecture</li>
                <li>RESTful API Design</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Mobile Development</h2>
              <ul class="tech-list">
                <li>Flutter / Dart</li>
                <li>Firebase (Auth, Firestore, Cloud Messaging)</li>
                <li>Provider & Bloc State Management</li>
                <li>Clean Architecture</li>
                <li>App Store & Play Store Deployment</li>
                <li>Push Notifications</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Frontend</h2>
              <ul class="tech-list">
                <li>TypeScript</li>
                <li>Astro (Static Sites)</li>
                <li>React / Next.js</li>
                <li>HTML5 / CSS3 / SCSS</li>
                <li>Tailwind CSS</li>
                <li>Responsive Design</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">AI & Machine Learning</h2>
              <ul class="tech-list">
                <li>OpenAI API Integration</li>
                <li>TensorFlow Lite</li>
                <li>Google ML Kit</li>
                <li>ChatGPT Integration</li>
                <li>NLP Applications</li>
                <li>AI-Powered Features</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Database & Storage</h2>
              <ul class="tech-list">
                <li>PostgreSQL</li>
                <li>SQL Server</li>
                <li>SQLite</li>
                <li>Redis (Caching)</li>
                <li>Firebase Firestore</li>
                <li>Cloud Storage</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">DevOps & Cloud</h2>
              <ul class="tech-list">
                <li>Docker & Kubernetes</li>
                <li>Git / GitHub Actions</li>
                <li>CI/CD Pipelines</li>
                <li>Azure</li>
                <li>Google Cloud Platform</li>
                <li>GitHub Pages</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Tools & IDEs</h2>
              <ul class="tech-list">
                <li>Visual Studio 2022</li>
                <li>VS Code</li>
                <li>Android Studio</li>
                <li>Xcode</li>
                <li>Postman / Insomnia</li>
                <li>Docker Desktop</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Methodologies</h2>
              <ul class="tech-list">
                <li>Clean Code</li>
                <li>Test-Driven Development (TDD)</li>
                <li>Agile / Scrum</li>
                <li>SOLID Principles</li>
                <li>Design Patterns</li>
                <li>Code Review</li>
              </ul>
            </Card>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .tech {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
    text-align: center;
  }

  .tech__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-6);
  }

  .category-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-4);
    padding-bottom: var(--spacing-3);
    border-bottom: 1px solid var(--color-border);
  }

  .tech-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .tech-list li {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-5);
    position: relative;
  }

  .tech-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 8px;
    height: 8px;
    background-color: var(--color-accent);
    border-radius: 2px;
  }
</style>
