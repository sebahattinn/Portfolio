---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Card from '../components/ui/Card.astro';
import '../styles/global.css';

const title = 'Tech Stack - Sebahattin';
const description = 'Technologies and tools used for building software solutions.';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sebotech-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Header siteTitle="Sebahattin" />
    
    <main class="main">
      <section class="tech">
        <div class="container">
          <h1 class="page-title">Tech Stack</h1>
          
          <div class="tech__grid">
            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Backend</h2>
              <ul class="tech-list">
                <li>C#</li>
                <li>.NET Core</li>
                <li>ASP.NET Web API</li>
                <li>Entity Framework</li>
                <li>gRPC</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Frontend</h2>
              <ul class="tech-list">
                <li>TypeScript</li>
                <li>Astro</li>
                <li>HTML/CSS</li>
                <li>React</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Mobile</h2>
              <ul class="tech-list">
                <li>Flutter</li>
                <li>Dart</li>
                <li>Firebase</li>
                <li>REST APIs</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Database</h2>
              <ul class="tech-list">
                <li>PostgreSQL</li>
                <li>SQL Server</li>
                <li>SQLite</li>
                <li>Redis</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">DevOps</h2>
              <ul class="tech-list">
                <li>Docker</li>
                <li>Git</li>
                <li>CI/CD</li>
                <li>Cloud Platforms</li>
              </ul>
            </Card>

            <Card variant="bordered" padding="lg">
              <h2 class="category-title">Tools</h2>
              <ul class="tech-list">
                <li>Visual Studio</li>
                <li>VS Code</li>
                <li>GitHub</li>
                <li>Postman</li>
              </ul>
            </Card>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .tech {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
    text-align: center;
  }

  .tech__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-6);
  }

  .category-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-4);
    padding-bottom: var(--spacing-3);
    border-bottom: 1px solid var(--color-border);
  }

  .tech-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .tech-list li {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-5);
    position: relative;
  }

  .tech-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 8px;
    height: 8px;
    background-color: var(--color-accent);
    border-radius: 2px;
  }
</style>
