---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Card from '../components/ui/Card.astro';
import '../styles/global.css';

const title = 'Experience - Sebahattin';
const description = 'Professional work history and career progression.';

const experiences = [
  {
    title: '.NET Intern',
    company: 'Dengage',
    type: 'Internship · On-site',
    period: 'Jan 2026 – Present · Bursa, Turkey',
    description: 'Joined Dengage\'s .NET team in mid-January 2026. Actively contributing to enterprise-level projects, experiencing firsthand how Clean Architecture and Domain-Driven Design (DDD) are applied in real-world production systems.',
    highlights: [
      'Working on enterprise .NET projects in a corporate environment',
      'Applying Clean Architecture and DDD in real production systems',
      'Gaining hands-on experience with ASP.NET Core and Entity Framework Core',
      'Collaborating within an experienced team using Agile methodologies'
    ]
  },
  {
    title: 'Backend Developer',
    company: 'EPARAF',
    type: 'Full-time · Hybrid',
    period: 'Aug 2025 – Present · Manisa, Turkey',
    description: 'Working on digital contract and payment systems as a Backend Developer. Building and maintaining enterprise-grade APIs and services for legally binding digital signature workflows.',
    highlights: [
      'Developing and maintaining backend APIs for digital contract workflows',
      'Working with Docker for containerized deployments',
      'Building services for legally binding digital signature systems',
      'Implementing Clean Architecture patterns in a production environment'
    ]
  },
  {
    title: 'Flutter Developer Intern',
    company: 'Performans Software',
    type: 'Internship · On-site',
    period: 'Jul 2025 – Sep 2025 · 3 months · Bursa, Turkey',
    description: 'Worked as a Flutter Developer intern at Performans Software. Gained hands-on experience in mobile application development using Flutter and Android Studio.',
    highlights: [
      'Mobile app development with Flutter and Dart',
      'Working with Android Studio in a professional environment',
      'Contributing to real mobile application features',
      'Learning mobile development best practices'
    ]
  },
  {
    title: 'Software Technical Support',
    company: 'Mikrotek Bilgisayar',
    type: 'Internship · On-site',
    period: 'Aug 2020 – Jul 2021 · 1 year · Bursa, Turkey',
    description: 'Took an active role in end-to-end operational processes of Micro Software-based ERP and commercial accounting software. Gained experience in software integration, installation, technical support, troubleshooting, process analysis, and customer relationship management.',
    highlights: [
      'ERP software installation and integration for enterprise clients',
      'Technical support and issue resolution for commercial accounting software',
      'Process analysis and workflow optimization',
      'Customer relationship management and end-user training'
    ]
  }
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sebotech-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Header siteTitle="Sebahattin" />
    
    <main class="main">
      <section class="experience">
        <div class="container container--narrow">
          <h1 class="page-title" data-i18n="experience.title">Experience</h1>
          
          <div class="timeline">
            {experiences.map((exp, index) => (
              <Card variant="bordered" padding="lg" class="timeline-item">
                <div class="timeline-header">
                  <div class="timeline-marker"></div>
                  <div class="timeline-info">
                    <h2 class="job-title">{exp.title}</h2>
                    <p class="job-company">{exp.company} · <span class="job-type">{exp.type}</span></p>
                    <p class="job-period">{exp.period}</p>
                  </div>
                </div>
                <p class="job-description">{exp.description}</p>
                <ul class="job-highlights">
                  {exp.highlights.map(highlight => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </Card>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .experience {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-border);
  }

  .timeline-item {
    position: relative;
    margin-left: var(--spacing-6);
  }

  .timeline-header {
    display: flex;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-4);
  }

  .timeline-marker {
    position: absolute;
    left: calc(-1 * var(--spacing-6) - 1px);
    top: 6px;
    width: 16px;
    height: 16px;
    background-color: var(--color-accent);
    border-radius: 50%;
    border: 3px solid var(--color-bg-secondary);
  }

  .timeline-info {
    flex: 1;
  }

  .job-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-1);
  }

  .job-company {
    font-size: var(--font-size-base);
    color: var(--color-accent);
    margin-bottom: var(--spacing-1);
  }

  .job-period {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
  }

  .job-type {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
  }

  .job-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-4);
  }

  .job-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .job-highlights li {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-5);
    position: relative;
  }

  .job-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 4px;
    height: 4px;
    background-color: var(--color-accent);
    border-radius: 50%;
  }
</style>
