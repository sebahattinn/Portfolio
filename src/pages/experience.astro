---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Card from '../components/ui/Card.astro';
import '../styles/global.css';

const title = 'Experience - Sebahattin';
const description = 'Professional work history and career progression.';

const experiences = [
  {
    title: 'Senior Full-Stack Developer',
    company: 'Freelance / Independent',
    period: '2022 - Present',
    description: 'Building premium software solutions for clients worldwide. Specializing in enterprise applications, AI integration, and cross-platform development.',
    highlights: [
      'Developed custom .NET solutions for financial institutions',
      'Built AI-powered Flutter applications with machine learning integration',
      'Delivered scalable microservices architecture for startups',
      'Consulted on digital transformation initiatives'
    ]
  },
  {
    title: 'Full-Stack Developer',
    company: 'E-Cart Digital Solutions',
    period: '2020 - 2022',
    description: 'Led development of e-commerce platforms and mobile applications. Focused on Flutter for cross-platform solutions and .NET for backend services.',
    highlights: [
      'Built Flutter e-commerce apps with 50k+ active users',
      'Developed RESTful APIs serving 1000+ requests/minute',
      'Implemented Firebase authentication and cloud messaging',
      'Reduced app load times by 60% through optimization'
    ]
  },
  {
    title: 'Software Developer',
    company: 'TechVenture Studios',
    period: '2018 - 2020',
    description: 'Full-stack development using C#, .NET Core, and modern JavaScript frameworks. Mobile development with Flutter.',
    highlights: [
      'Developed 5+ production Flutter applications',
      'Built real-time chat applications with WebSocket integration',
      'Created custom UI components and design systems',
      'Implemented CI/CD pipelines for automated deployments'
    ]
  },
  {
    title: 'Junior Software Developer',
    company: 'StartupHub Agency',
    period: '2016 - 2018',
    description: 'Started professional career building web and mobile applications. Gained expertise in C#, ASP.NET, and mobile development.',
    highlights: [
      'Built responsive web applications for local businesses',
      'Learned Clean Code principles and best practices',
      'Contributed to open-source Flutter packages',
      'Participated in agile development methodologies'
    ]
  }
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sebotech-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Header siteTitle="Sebahattin" />
    
    <main class="main">
      <section class="experience">
        <div class="container container--narrow">
          <h1 class="page-title">Experience</h1>
          
          <div class="timeline">
            {experiences.map((exp, index) => (
              <Card variant="bordered" padding="lg" class="timeline-item">
                <div class="timeline-header">
                  <div class="timeline-marker"></div>
                  <div class="timeline-info">
                    <h2 class="job-title">{exp.title}</h2>
                    <p class="job-company">{exp.company}</p>
                    <p class="job-period">{exp.period}</p>
                  </div>
                </div>
                <p class="job-description">{exp.description}</p>
                <ul class="job-highlights">
                  {exp.highlights.map(highlight => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </Card>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .main {
    padding-top: var(--header-height);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .experience {
    padding: var(--spacing-16) 0;
    flex: 1;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-8);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-border);
  }

  .timeline-item {
    position: relative;
    margin-left: var(--spacing-6);
  }

  .timeline-header {
    display: flex;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-4);
  }

  .timeline-marker {
    position: absolute;
    left: calc(-1 * var(--spacing-6) - 1px);
    top: 6px;
    width: 16px;
    height: 16px;
    background-color: var(--color-accent);
    border-radius: 50%;
    border: 3px solid var(--color-bg-secondary);
  }

  .timeline-info {
    flex: 1;
  }

  .job-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-1);
  }

  .job-company {
    font-size: var(--font-size-base);
    color: var(--color-accent);
    margin-bottom: var(--spacing-1);
  }

  .job-period {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
  }

  .job-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-4);
  }

  .job-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .job-highlights li {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-left: var(--spacing-5);
    position: relative;
  }

  .job-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 4px;
    height: 4px;
    background-color: var(--color-accent);
    border-radius: 50%;
  }
</style>
